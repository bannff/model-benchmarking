{
  "name": "Model Benchmarking Codespace",
  "dockerFile": "../Dockerfile",
  "context": "..",
  "workspaceFolder": "/workspaces/${localWorkspaceFolderBasename}",
  "overrideCommand": true,
  "runArgs": ["--init"],
  "remoteUser": "appuser",
  "updateRemoteUserUID": true,
  "postCreateCommand": "pip install --user --upgrade pip setuptools wheel && (pip install --user -r requirements-dev.txt || pip install --user . || true)",
  "customizations": {
    "vscode": {
      "settings": {
        "terminal.integrated.shell.linux": "/bin/bash"
      },
      "extensions": [
        "ms-python.python",
        "ms-azuretools.vscode-docker",
        "github.vscode-pull-request-github"
      ]
    }
  }
}
